{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null",
        ".read": "auth != null"
      }
    },
    "groups": {
      ".read": "auth != null",
      "$groupId": {
        ".write": "auth != null",
        ".read": "auth != null"
      }
    },
    "rooms": {
      "__public__": {
        ".read": "auth != null",
        ".write": "auth != null",
        "messages": { ".indexOn": ["timestamp"] },
        "lastRead": {
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      },
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "messages": { ".indexOn": ["timestamp"] },
        "lastRead": {
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    }
  }
}
